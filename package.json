{
  "name": "oj-backend",
  "version": "1.0.0",
  "description": "Fastify TypeScript backend for OJ Multimedia",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "dev:worker": "tsx watch src/worker.ts",
    "seed": "tsx src/seed/run.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:phase": "vitest run tests/phase",
    "test:phase:unit": "vitest run tests/phase/unit",
    "test:phase:integration": "vitest run tests/phase/integration",
    "test:phase:e2e": "vitest run tests/phase/e2e",
    "audit": "npm audit",
    "audit:ci": "npm audit --audit-level=high",
    "release:check": "npm run type-check && npm run lint && npm run format:check && npm run test:unit && npm run test:integration && npm run test:phase:integration && npm run audit:ci"
  },
  "keywords": [
    "fastify",
    "typescript",
    "backend",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.974.0",
    "@aws-sdk/lib-storage": "^3.974.0",
    "@aws-sdk/s3-request-presigner": "^3.974.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@react-email/components": "^1.0.7",
    "@react-email/render": "^2.0.4",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.66.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.1",
    "fastify-plugin": "^5.1.0",
    "google-auth-library": "^10.5.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.2.1",
    "music-metadata": "^11.12.3",
    "nodemailer": "^7.0.12",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "socket.io": "^4.8.3",
    "ts-custom-error": "^3.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.10",
    "@types/nodemailer": "^7.0.5",
    "@types/react": "^18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "vitest": "^4.1.5"
  }
}
