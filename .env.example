# # Server Configuration
# NODE_ENV=development
# PORT=4400
# HOST=0.0.0.0

# # Database
# DATABASE_URL=mongodb://localhost:27017/oj-multimedia

# # JWT Configuration
# JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT_EXPIRES_IN=7d
# REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-in-production
# REFRESH_TOKEN_EXPIRES_IN=30d
# # Cookie max age in seconds (7 days, 30 days)
# ACCESS_COOKIE_MAX_AGE=604800
# REFRESH_COOKIE_MAX_AGE=2592000

# # Token Cookie Names
# TOKEN_COOKIE_ACCESS=oj-acc-token
# TOKEN_COOKIE_REFRESH=oj-ref-token

# # Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# # Redis Configuration
# REDIS_URL=redis://localhost:6379/0
# CACHE_EXPIRY=3600

# # AWS S3 Configuration
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=

# # Cloudflare R2 Configuration
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_FOLDER_PREFIX=staging-files
# R2_CDN_URL=
# R2_PUBLIC_URL=

# # Email Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@example.com
# EMAIL_FROM_NAME=OJ Multimedia

# # Branding
# APP_NAME=OJ Multimedia
# PRIMARY_COLOR=#2563EB
# SECONDARY_COLOR=#404040
# FONT_FAMILY=Poppins
# SUPPORT_EMAIL=ohemultimedia@gmail.com
# LOGO_URL=

# # CORS
# CORS_ORIGIN=http://localhost:3000

# # App URLs
# ADMIN_APP_URL=http://localhost:3001
# CLIENT_APP_URL=http://localhost:3000

# # Rate Limiting (max requests per time window in ms)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_TIME_WINDOW=60000
