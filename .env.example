# Server Configuration
NODE_ENV=development
PORT=4400
HOST=0.0.0.0
# RUN_WORKER=true
# Colocate BullMQ worker with API in dev only. Production: npm run start:worker as a separate process.

# Database
DATABASE_URL=mongodb://localhost:27017/oj-multimedia
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_RETRY_WRITES=true

# JWT Configuration
# Required in production (min 16 chars, no placeholders):
JWT_SECRET=dev-only-jwt-secret-32chars-minimum!
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=dev-only-refresh-secret-32chars-min!
REFRESH_TOKEN_EXPIRES_IN=30d
# Cookie max age in seconds (1 hour access, 30 days refresh)
ACCESS_COOKIE_MAX_AGE=3600
REFRESH_COOKIE_MAX_AGE=2592000
REQUIRE_REFRESH_TOKEN=false

# Cookie signing (separate from JWT in production)
COOKIE_SECRET=dev-only-cookie-secret-32chars-min!

# Token Cookie Names
TOKEN_COOKIE_ACCESS=oj-acc-token
TOKEN_COOKIE_REFRESH=oj-ref-token

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# YouTube Data API (video duration probe)
YOUTUBE_API_KEY=

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CACHE_EXPIRY=3600

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_FOLDER_PREFIX=staging-files
R2_CDN_URL=
R2_PUBLIC_URL=
# Browser uploads troubleshooting (audio/video/images):
# 1) R2 bucket CORS: AllowedOrigins = admin + public site origins; Methods = PUT, HEAD; AllowedHeaders = Content-Type
# 2) Set R2_CDN_URL (or R2_PUBLIC_URL) so presign responses return playable publicUrl values
# 3) Presigned PUT Content-Type must match signed value (frontend sends extension-derived MIME)
# 4) SDK checksum workaround required (r2 client uses requestChecksumCalculation=WHEN_REQUIRED)
# 5) Verify upload in DevTools: presign 200, PUT to *.r2.cloudflarestorage.com 200/204, documents/verify -> verified

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=OJ Multimedia

# Branding
APP_NAME=OJ Multimedia
PRIMARY_COLOR=#2563EB
SECONDARY_COLOR=#404040
FONT_FAMILY=Poppins
SUPPORT_EMAIL=ohemultimedia@gmail.com
LOGO_URL=

# CORS (comma-separated origins for public site + admin app)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# App URLs
ADMIN_APP_URL=http://localhost:3001
CLIENT_APP_URL=http://localhost:3000

# Frontend on-demand ISR (optional — POST to oj-multimedia /api/revalidate)
FRONTEND_REVALIDATION_URL=http://localhost:3000/api/revalidate
REVALIDATION_SECRET=change-me-in-production-min-16-chars
# FRONTEND_REVALIDATION_SECRET=change-me-in-production-min-16-chars

# Rate Limiting (max requests per time window in ms)
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000

# Search (long-term Atlas Search rollout)
USE_ATLAS_SEARCH=false

# Logging (stdout)
# pretty = multiline human-readable (default off in production, on in dev/staging)
# json = one JSON object per line (for log aggregators)
LOG_FORMAT=pretty
LOG_PRETTY=1
LOG_LEVEL=info

# Observability (internal/staging only — do not expose publicly without auth)
ENABLE_METRICS_ROUTE=1
