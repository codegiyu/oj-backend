# # Server Configuration
# NODE_ENV=development
# PORT=4400
# HOST=0.0.0.0
# RUN_WORKER=true
# Colocate BullMQ worker with API in dev only. Production: npm run start:worker as a separate process.

# # Database
# DATABASE_URL=mongodb://localhost:27017/oj-multimedia
# MONGO_MAX_POOL_SIZE=10
# MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
# MONGO_RETRY_WRITES=true

# # JWT Configuration
# Required in production (min 16 chars, no placeholders):
# JWT_SECRET=
# JWT_EXPIRES_IN=1h
# REFRESH_TOKEN_SECRET=
# REFRESH_TOKEN_EXPIRES_IN=30d
# # Cookie max age in seconds (1 hour access, 30 days refresh)
# ACCESS_COOKIE_MAX_AGE=3600
# REFRESH_COOKIE_MAX_AGE=2592000
# REQUIRE_REFRESH_TOKEN=true

# # Token Cookie Names
# TOKEN_COOKIE_ACCESS=oj-acc-token
# TOKEN_COOKIE_REFRESH=oj-ref-token

# # Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# # YouTube Data API (video duration probe)
# YOUTUBE_API_KEY=

# # Redis Configuration
# REDIS_URL=redis://localhost:6379/0
# CACHE_EXPIRY=3600

# # AWS S3 Configuration
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=

# # Cloudflare R2 Configuration
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_FOLDER_PREFIX=staging-files
# R2_CDN_URL=
# R2_PUBLIC_URL=
# Browser uploads: set bucket CORS AllowedOrigins to CLIENT_APP_URL (e.g. https://www.ojmultimedia.com).
# Presigned URLs must not include SDK checksum params (r2 client uses requestChecksumCalculation=WHEN_REQUIRED).

# # Email Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@example.com
# EMAIL_FROM_NAME=OJ Multimedia

# # Branding
# APP_NAME=OJ Multimedia
# PRIMARY_COLOR=#2563EB
# SECONDARY_COLOR=#404040
# FONT_FAMILY=Poppins
# SUPPORT_EMAIL=ohemultimedia@gmail.com
# LOGO_URL=

# # CORS (comma-separated origins for public site + admin app)
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# # App URLs
# ADMIN_APP_URL=http://localhost:3001
# CLIENT_APP_URL=http://localhost:3000

# # Frontend on-demand ISR (optional — POST to oj-multimedia /api/revalidate)
# FRONTEND_REVALIDATION_URL=http://localhost:3000/api/revalidate
# REVALIDATION_SECRET=change-me-in-production-min-16-chars
# FRONTEND_REVALIDATION_SECRET=change-me-in-production-min-16-chars

# # Rate Limiting (max requests per time window in ms)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_TIME_WINDOW=60000

# # Logging (stdout)
# # pretty = multiline human-readable (default off in production, on in dev/staging)
# # json = one JSON object per line (for log aggregators)
# LOG_FORMAT=pretty
# LOG_PRETTY=1
# LOG_LEVEL=info

# # Search (long-term Atlas Search rollout)
# USE_ATLAS_SEARCH=false

# # Observability (internal/staging only — do not expose publicly without auth)
# ENABLE_METRICS_ROUTE=1
